# Archivo de Ejemplo de Variables de Entorno para Signal Server

# Este archivo contiene todas las variables de entorno necesarias para configurar el servidor de señalización.
# Copia este archivo a '.env' y ajusta los valores según tu entorno.

# ==============================================================================
# CONFIGURACIÓN GENERAL DEL SERVIDOR
# ==============================================================================

# PORT: Puerto en el que el servidor principal escuchará las conexiones HTTPS/WSS.
# Valor por defecto: 8080
PORT=8080

# LISTEN_ADDRESS: Dirección IP en la que el servidor principal escuchará.
# Usa '0.0.0.0' para escuchar en todas las interfaces disponibles.
# Usa '127.0.0.1' para escuchar solo en localhost.
# Valor por defecto: 0.0.0.0
LISTEN_ADDRESS=0.0.0.0

# TLS_CERT_PATH: Ruta absoluta al archivo del certificado TLS (ej. cert.pem).
# REQUERIDO: El servidor requiere HTTPS/WSS para funcionar.
TLS_CERT_PATH=./certs/cert.pem

# TLS_KEY_PATH: Ruta absoluta al archivo de la clave privada TLS (ej. key.key).
# REQUERIDO: El servidor requiere HTTPS/WSS para funcionar.
TLS_KEY_PATH=./certs/key.key

# ALLOWED_ORIGINS: Lista de orígenes permitidos para conexiones WebSocket (CORS).
# Separa múltiples orígenes con comas (ej. "https://example.com,https://another.com").
# Si está vacío, se permiten todos los orígenes (NO RECOMENDADO PARA PRODUCCIÓN).
# Ejemplo: ALLOWED_ORIGINS=https://your-frontend.com,https://your-other-app.com
ALLOWED_ORIGINS=

# ==============================================================================
# CONFIGURACIÓN DE WEBSOCKET
# ==============================================================================

# WEBSOCKET_PING_PERIOD: Intervalo para enviar mensajes PING a los clientes.
# Ayuda a mantener la conexión viva y detectar clientes desconectados.
# Valor por defecto: 10s (10 segundos)
WEBSOCKET_PING_PERIOD=10s

# WEBSOCKET_PONG_WAIT: Tiempo máximo para esperar un mensaje PONG del cliente después de un PING.
# Si no se recibe un PONG, la conexión se considera muerta.
# Valor por defecto: 60s (60 segundos)
WEBSOCKET_PONG_WAIT=60s

# WEBSOCKET_MAX_MESSAGE_SIZE: Tamaño máximo permitido para un mensaje WebSocket entrante en bytes.
# Valor por defecto: 512 (bytes)
WEBSOCKET_MAX_MESSAGE_SIZE=512

# WEBSOCKET_WRITE_TIMEOUT: Tiempo máximo para escribir un mensaje en la conexión WebSocket.
# Valor por defecto: 5s (5 segundos)
WEBSOCKET_WRITE_TIMEOUT=5s

# MAX_TOTAL_CONNECTIONS: Número máximo total de conexiones WebSocket que el servidor aceptará.
# Valor por defecto: 1000
MAX_TOTAL_CONNECTIONS=1000


# RATE_LIMIT_PER_SECOND: Número máximo de mensajes por segundo que un cliente puede enviar.
# Valor por defecto: 10 (mensajes por segundo)
RATE_LIMIT_PER_SECOND=10

# RATE_LIMIT_BURST: Capacidad de ráfaga para el limitador de tasa.
# Permite que un cliente envíe un número de mensajes por encima del límite por un corto período.
# Valor por defecto: 20
RATE_LIMIT_BURST=20

# ==============================================================================
# CONFIGURACIÓN DE AUTENTICACIÓN JWT
# ==============================================================================

# JWT_SECRET: Clave secreta utilizada para firmar y verificar los JWT.
# REQUERIDO: Debe ser una cadena larga y segura.
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# JWT_ISSUER: Identificador del emisor del JWT.
# REQUERIDO: Debe coincidir con el 'iss' claim en los JWT emitidos por tu servicio de autenticación.
JWT_ISSUER=your_app_jwt_issuer

# ==============================================================================
# CONFIGURACIÓN DE LLAMADAS Y SALAS
# ==============================================================================

# CALL_MAX_DURATION_MINUTES: Duración máxima global permitida para cualquier llamada en minutos.
# Si el 'call_time' del JWT del caller es mayor, se usará este valor.
# Valor por defecto: 60 (minutos)
CALL_MAX_DURATION_MINUTES=60

# Duración en segundos antes de que una solicitud de llamada sin respuesta se cancele automáticamente.
CALL_REQUEST_TIMEOUT_SECONDS=30

# Máximo de conexiones WebSocket simultáneas permitidas por el mismo UserID.
# Un valor de 1 fuerza una política de "sesión única" (un nuevo login desplaza al antiguo).
# Valores mayores podrían permitir que un usuario esté conectado en múltiples dispositivos a la vez.
MAX_CONN_PER_USER=1

# ROOM_MAX_CLIENTS: Número máximo de clientes permitidos en una sala de llamada.
# Para llamadas 1 a 1, este valor debe ser 2.
# Valor por defecto: 2
ROOM_MAX_CLIENTS=2

# ==============================================================================
# CONFIGURACIÓN DE COMUNICACIÓN BACKEND-TO-BACKEND (CodeIgniter)
# ==============================================================================

# API_WEBHOOK_URL: URL base de tu backend CodeIgniter.
# El servidor Go usará esta URL para enviar webhooks de fin de llamada (facturación)
# y actualizaciones de estado del oyente (ocupado, disponible).
# Ejemplo: https://api.tu-dominio.com
API_WEBHOOK_URL=https://eypelame.noxthar.com

# API_WEBHOOK_SECRET: Llave maestra para autenticar las peticiones Go -> PHP.
# REQUERIDO: Debe coincidir exactamente con el valor esperado por CodeIgniter
# en el header 'X-API-KEY'.
API_WEBHOOK_SECRET=your_super_secret_webhook_key_here

# ==============================================================================
# CONFIGURACIÓN DE NOTIFICACIONES FCM (Firebase Cloud Messaging)
# ==============================================================================

# FCM_SERVICE_ACCOUNT_KEY_PATH: Ruta absoluta al archivo JSON de la clave de cuenta de servicio de Firebase.
# Necesario para enviar notificaciones push a través de FCM.
# Si está vacío, las notificaciones FCM no se enviarán.
# Ejemplo: FCM_SERVICE_ACCOUNT_KEY_PATH=./firebase/serviceAccountKey.json
FCM_SERVICE_ACCOUNT_KEY_PATH=

# ==============================================================================
# CONFIGURACIÓN DE MÉTRICAS (Prometheus)
# ==============================================================================

# ENABLE_METRICS: Habilita o deshabilita la exposición de métricas de Prometheus.
# Valor por defecto: false
ENABLE_METRICS=false

# METRICS_PORT: Puerto en el que el servidor de métricas escuchará.
# Valor por defecto: 8081
METRICS_PORT=8081

# METRICS_LISTEN_ADDR: Dirección IP en la que el servidor de métricas escuchará.
# Usa '127.0.0.1' para restringir el acceso solo a la máquina local (RECOMENDADO).
# Usa '0.0.0.0' para exponer las métricas públicamente (NO RECOMENDADO).
# Valor por defecto: 127.0.0.1
METRICS_LISTEN_ADDR=127.0.0.1

# ==============================================================================
# CONFIGURACIÓN DE LOGGING (DUAL SOURCE)
# ==============================================================================

# CONSOLE_LOG_LEVEL: Nivel mínimo de logs para la consola humana (debug, info, warn, error, fatal).
# Valor por defecto: info
CONSOLE_LOG_LEVEL=info

# FILE_LOG_LEVEL: Nivel mínimo de logs para el archivo signalserver.log (Loki/Grafana).
# Valor por defecto: debug (Recomendado para auditoría total)
FILE_LOG_LEVEL=debug

# LOG_FILE_PATH: Ruta al archivo donde se escribirán los logs de tráfico estructurado.
# Ejemplo: LOG_FILE_PATH=./logs/signalserver.log
LOG_FILE_PATH=./logs/signalserver.log

# SHOW_BANNER: Muestra el banner de inicio del servidor en la consola.
# Valor por defecto: true
SHOW_BANNER=true

# CONSOLE_VERBOSE: Controla si se muestra salida en la terminal.
# Valor por defecto: true
CONSOLE_VERBOSE=true
